{
  "name": "casa-app",
  "version": "1.0.0",
  "private": true,
  "description": "App de gestión del hogar (calendario, compra, gastos, tareas, menú, notas) con backend Express + MongoDB y frontend React servidos desde una única URL.",
  "scripts": {
    "install:all": "npm install && npm install --prefix client",
    "build": "npm install --prefix client && npm run build --prefix client",
    "start": "node server/index.js",
    "dev:server": "nodemon server/index.js",
    "dev:client": "npm run dev --prefix client",
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18"
  }
}
